# MarketForge GEO — Variables de configuration client
# Copier ce fichier et remplir les valeurs pour chaque client

# === SECRETS GitHub (Settings > Secrets) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
FTP_SERVER=ftp.client.fr
FTP_USERNAME=user@client.fr
FTP_PASSWORD=motdepasse

# === VARIABLES GitHub (Settings > Variables) ===

# Podcast
RSS_URL=https://feed.ausha.co/XXXXXXXX
BLOG_NAME=Nom du Podcast
COMPANY_NAME=Nom Entreprise Cliente
ACCENT_COLOR=#2e8bd6

# Site client
SITE_BASE_URL=https://www.client.fr
FTP_SERVER_DIR=/client.fr/article-faq/

# CTAs (recommandes)
PODCAST_URL=https://open.spotify.com/show/XXXXXXXX
CONTACT_URL=https://www.client.fr/contact
LISTENLY_PODCAST_URL=https://listenly.fr/podcast/nom-du-podcast

# Comportement
MAX_NEW_PER_RUN=1
